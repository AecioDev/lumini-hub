# URL da API - Já configurada no Vercel
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Configurações de autenticação
NEXT_PUBLIC_JWT_EXPIRATION=3600 # Tempo de expiração do token em segundos (1 hora)

# Configurações da aplicação
NEXT_PUBLIC_APP_NAME=Sistema ERP
NEXT_PUBLIC_APP_VERSION=3.0.0

# Configurações de upload de arquivos (se implementado)
NEXT_PUBLIC_MAX_FILE_SIZE=5242880 # 5MB em bytes

# Configurações de paginação padrão
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=10

# Configurações de timeout de requisições (em milissegundos)
NEXT_PUBLIC_API_TIMEOUT=30000 # 30 segundos